# ==================== Database ====================
DATABASE_URL=postgresql://postgres:password@localhost:5432/echosql

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Cache TTLs
EMBEDDING_CACHE_TTL_HOURS=24
QUERY_RESULT_CACHE_TTL_MINUTES=5

# ==================== Ollama ====================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen:7b-chat-q4_K_M
OLLAMA_INFERENCE_TIMEOUT=5

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_TIMEOUT=10

# ==================== Embeddings ====================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_ENABLED=true
QUERY_RESULT_CACHE_ENABLED=true

# ==================== SQL ====================
SQL_SIMILARITY_THRESHOLD=0.85
MAX_INFERENCE_QUEUE_SIZE=50

# ==================== Observability ====================
# Traces are always written to backend/logs/traces.jsonl.
# To also ship them to Grafana Tempo (and view in Grafana at :3001):
#   docker compose -f docker-compose.observability.yml up -d
#   Then uncomment the line below.
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
